    {
      "text": "%md\n## рџ“Ґ Step 3: TбєЈi Multi-Source Datasets\n\nTбєЈi tб»« HuggingFace (AxonData sub-datasets) + chuбє©n bб»‹ folder cho datasets offline:\n- **OULU-NPU**: TбєЈi thб»§ cГґng tб»« https://sites.google.com/site/oulunpudatabase/\n- **Replay-Attack**: https://www.idiap.ch/en/scientific-research/data/replayattack\n- **CASIA-FASD**: https://github.com/ankushpanwar19/Face-Anti-spoofing\n- **AxonData subs**: TбєЈi tб»± Д‘б»™ng tб»« HuggingFace",
      "user": "anonymous",
      "config": {},
      {
      "text": "%python\nprint('=== CODE MOI ===')\nimport sys, os, time\nsys.path.insert(0, os.path.abspath('./extra_libs'))\n\n# Ep HuggingFace cache vao workspace (tranh loi quyen)\nos.environ['HF_HOME'] = os.path.abspath('./hf_home')\nos.environ['HUGGINGFACE_HUB_CACHE'] = os.path.abspath('./hf_home/cache')\nos.makedirs(os.environ['HF_HOME'], exist_ok=True)\nos.makedirs(os.environ['HUGGINGFACE_HUB_CACHE'], exist_ok=True)\n\nfrom huggingface_hub import snapshot_download\n\nHF_TOKEN = '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'\n\nWORK_DIR = os.path.join('.', 'Workspace', 'minifasnetv2')\nos.makedirs(WORK_DIR, exist_ok=True)\nDATA_ROOT = os.path.join(WORK_DIR, 'AntiSpoofData')\nos.makedirs(DATA_ROOT, exist_ok=True)\n\nDATASETS = {\n    'Selfie_Real': 'AxonData/Selfie_and_Official_ID_Photo_Dataset',\n    'CASIA_FASD': 'ybelkada/casia-fasd',\n    'Replay_Attack': 'ybelkada/replay-attack',\n}\n\nfor name, repo in DATASETS.items():\n    local = os.path.join(DATA_ROOT, name)\n    os.makedirs(local, exist_ok=True)\n    print(f'[DOWNLOAD] {repo} -> {name}')\n    t0 = time.time()\n    try:\n        snapshot_download(\n            repo_id=repo,\n            repo_type='dataset',\n            local_dir=local,\n            token=HF_TOKEN,\n            resume_download=True\n        )\n        print(f'  OK ({time.time()-t0:.0f}s)')\n    except Exception as e:\n        print(f'  ERROR: {e}')",
